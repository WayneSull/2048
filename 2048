<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>2048</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #faf8ef;
  --accent: #776e65;
  --primary: #8f7a66;
  --primary-d: #7c6a58;
  --tile-bg: #bbada0;
  --white: #f9f6f2;
}

body {
  background: var(--bg);
  font-family: Arial, sans-serif;
  min-height: 100vh;
  user-select: none;
}

/* ===== PAGE SYSTEM ===== */
.page {
  position: fixed; inset: 0;
  overflow-y: auto;
  display: flex; flex-direction: column; align-items: center;
  padding: 20px;
  transition: opacity 0.22s, transform 0.22s;
}
.page.hidden { opacity: 0; pointer-events: none; transform: translateY(18px); }

/* ===== AUTH ===== */
.auth-logo {
  font-size: 70px; font-weight: 900; color: var(--accent);
  margin: 36px 0 6px; line-height: 1;
}
.auth-tagline { color: #a09080; font-size: 14px; margin-bottom: 28px; }

.auth-card {
  background: #fff; border-radius: 16px; padding: 32px;
  width: 100%; max-width: 380px;
  box-shadow: 0 4px 28px rgba(0,0,0,0.09);
}
.auth-card h2 { font-size: 22px; color: var(--accent); margin-bottom: 22px; text-align: center; }

.form-group { margin-bottom: 15px; }
.form-group label {
  display: block; font-size: 12px; font-weight: 700; color: var(--accent);
  margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;
}
.form-group input {
  width: 100%; padding: 11px 14px; border: 2px solid #e0d8d0; border-radius: 8px;
  font-size: 15px; color: var(--accent); background: var(--bg); outline: none;
  transition: border-color 0.15s;
}
.form-group input:focus { border-color: var(--primary); }

.btn-auth {
  width: 100%; padding: 13px; background: var(--primary); color: var(--white);
  border: none; border-radius: 8px; font-size: 16px; font-weight: 700;
  cursor: pointer; margin-top: 6px; transition: background 0.15s;
}
.btn-auth:hover { background: var(--primary-d); }

.auth-switch { text-align: center; margin-top: 18px; color: #a09080; font-size: 14px; }
.auth-switch a { color: var(--primary); font-weight: 700; cursor: pointer; }
.auth-switch a:hover { text-decoration: underline; }

.err {
  background: #ffe3e3; color: #c0392b; border-radius: 6px;
  padding: 9px 14px; font-size: 13px; margin-bottom: 12px; display: none;
}
.err.show { display: block; }

/* ===== GAME ===== */
.g-header {
  width: 100%; max-width: 500px;
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 8px; padding-top: 4px;
}
.g-title { font-size: 52px; font-weight: 900; color: var(--accent); line-height: 1; }

.h-right { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
.scores { display: flex; gap: 8px; }
.score-box {
  background: var(--tile-bg); border-radius: 6px; padding: 7px 14px;
  text-align: center; min-width: 64px;
}
.score-label { font-size: 10px; font-weight: 700; color: #eee4da; text-transform: uppercase; letter-spacing: 1px; }
.score-val   { font-size: 20px; font-weight: 900; color: #fff; line-height: 1.2; }

.btn-row { display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; }
.gbtn {
  background: var(--primary); color: var(--white); border: none; border-radius: 6px;
  padding: 8px 13px; font-size: 13px; font-weight: 700; cursor: pointer;
  transition: background 0.15s; white-space: nowrap;
}
.gbtn:hover { background: var(--primary-d); }

.user-bar {
  width: 100%; max-width: 500px;
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 8px; padding: 0 2px;
}
.user-greeting { color: var(--accent); font-size: 14px; font-weight: 600; }
.user-greeting em { color: #f67c5f; font-style: normal; }
.user-rank { color: #a09080; font-size: 13px; }

.game-wrapper { position: relative; width: 100%; max-width: 500px; }

.board {
  background: var(--tile-bg); border-radius: 10px; padding: 12px;
  display: grid; grid-template-columns: repeat(4,1fr); gap: 12px;
  width: 100%; aspect-ratio: 1;
}
.cell { background: rgba(238,228,218,.35); border-radius: 6px; }

.tiles-layer {
  position: absolute; top: 12px; left: 12px; right: 12px; bottom: 12px;
  pointer-events: none;
}
.tile {
  position: absolute; border-radius: 6px;
  display: flex; align-items: center; justify-content: center; font-weight: 900;
  transition: left .1s ease, top .1s ease;
}
.tile.new   { animation: pop   .15s ease .1s both; }
.tile.merge { animation: burst .2s  ease .1s both; }

@keyframes pop   { 0%{transform:scale(0);opacity:0} 60%{transform:scale(1.12)} 100%{transform:scale(1);opacity:1} }
@keyframes burst { 0%{transform:scale(1)} 50%{transform:scale(1.2)} 100%{transform:scale(1)} }

.t2    {background:#eee4da;color:#776e65}
.t4    {background:#ede0c8;color:#776e65}
.t8    {background:#f2b179;color:#f9f6f2}
.t16   {background:#f59563;color:#f9f6f2}
.t32   {background:#f67c5f;color:#f9f6f2}
.t64   {background:#f65e3b;color:#f9f6f2}
.t128  {background:#edcf72;color:#f9f6f2}
.t256  {background:#edcc61;color:#f9f6f2}
.t512  {background:#edc850;color:#f9f6f2}
.t1024 {background:#edc53f;color:#f9f6f2}
.t2048 {background:#edc22e;color:#f9f6f2}
.tsuper{background:#3c3a32;color:#f9f6f2}

.overlay {
  position: absolute; inset: 0; background: rgba(250,248,239,.78);
  border-radius: 10px; display: none; flex-direction: column;
  align-items: center; justify-content: center; gap: 14px; z-index: 10;
}
.overlay.show { display: flex; }
.overlay-title { font-size: 38px; font-weight: 900; color: var(--accent); }

.g-hint { color: #a09080; font-size: 12px; margin-top: 8px; text-align: center; width: 100%; max-width: 500px; }

/* ===== LEADERBOARD ===== */
.lb-header {
  width: 100%; max-width: 500px;
  display: flex; align-items: center; justify-content: space-between;
  margin: 16px 0 20px;
}
.lb-title { font-size: 28px; font-weight: 900; color: var(--accent); }

.lb-list { width: 100%; max-width: 500px; display: flex; flex-direction: column; gap: 10px; padding-bottom: 24px; }

.lb-item {
  background: #fff; border-radius: 10px; padding: 14px 18px;
  display: flex; align-items: center; gap: 14px;
  box-shadow: 0 2px 10px rgba(0,0,0,.06); transition: transform .15s;
  border: 2px solid transparent;
}
.lb-item:hover { transform: translateX(4px); }
.lb-item.me { background: #fff8f0; border-color: #f2b179; }

.lb-rank { font-size: 22px; font-weight: 900; width: 34px; text-align: center; flex-shrink: 0; }
.rank-1   { color:#f1c40f }
.rank-2   { color:#95a5a6 }
.rank-3   { color:#cd7f32 }
.rank-n   { color:#bbada0; font-size: 16px; }

.lb-avatar {
  width: 44px; height: 44px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 19px; font-weight: 900; color: #fff; flex-shrink: 0;
}
.lb-info { flex: 1; min-width: 0; }
.lb-name { font-size: 15px; font-weight: 700; color: var(--accent); display: flex; align-items: center; gap: 6px; }
.lb-badge { font-size: 11px; color: #f67c5f; font-weight: 700; }
.lb-slabel { font-size: 11px; color: #a09080; margin-top: 2px; }
.lb-score { font-size: 22px; font-weight: 900; color: #f67c5f; }
.lb-empty { text-align: center; color: #bbada0; font-size: 15px; padding: 40px; }

.lb-stats {
  width: 100%; max-width: 500px;
  display: flex; gap: 10px; margin-bottom: 16px;
}
.lb-stat-box {
  flex: 1; background: var(--tile-bg); border-radius: 8px;
  padding: 12px; text-align: center;
}
.lb-stat-num { font-size: 24px; font-weight: 900; color: #fff; }
.lb-stat-lbl { font-size: 11px; color: #eee4da; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; margin-top: 2px; }
</style>
</head>
<body>

<!-- ========== LOGIN ========== -->
<div id="page-login" class="page">
  <div class="auth-logo">2048</div>
  <div class="auth-tagline">合并数字，挑战 2048！</div>
  <div class="auth-card">
    <h2>登录账号</h2>
    <div id="login-err" class="err"></div>
    <div class="form-group">
      <label>用户名</label>
      <input id="l-user" type="text" placeholder="请输入用户名" autocomplete="username">
    </div>
    <div class="form-group">
      <label>密码</label>
      <input id="l-pass" type="password" placeholder="请输入密码" autocomplete="current-password">
    </div>
    <button class="btn-auth" id="login-btn">登 录</button>
    <div class="auth-switch">没有账号？<a id="to-reg">立即注册</a></div>
  </div>
</div>

<!-- ========== REGISTER ========== -->
<div id="page-register" class="page hidden">
  <div class="auth-logo">2048</div>
  <div class="auth-tagline">创建账号，开始挑战！</div>
  <div class="auth-card">
    <h2>注册账号</h2>
    <div id="reg-err" class="err"></div>
    <div class="form-group">
      <label>用户名</label>
      <input id="r-user" type="text" placeholder="2-12 位（字母/数字/中文）" autocomplete="username">
    </div>
    <div class="form-group">
      <label>密码</label>
      <input id="r-pass" type="password" placeholder="至少 6 位" autocomplete="new-password">
    </div>
    <div class="form-group">
      <label>确认密码</label>
      <input id="r-conf" type="password" placeholder="再次输入密码" autocomplete="new-password">
    </div>
    <button class="btn-auth" id="reg-btn">注册并进入游戏</button>
    <div class="auth-switch">已有账号？<a id="to-login">返回登录</a></div>
  </div>
</div>

<!-- ========== GAME ========== -->
<div id="page-game" class="page hidden">
  <div class="g-header">
    <div class="g-title">2048</div>
    <div class="h-right">
      <div class="scores">
        <div class="score-box">
          <div class="score-label">分数</div>
          <div class="score-val" id="score">0</div>
        </div>
        <div class="score-box">
          <div class="score-label">最高</div>
          <div class="score-val" id="best">0</div>
        </div>
      </div>
      <div class="btn-row">
        <button class="gbtn" id="new-btn">新游戏</button>
        <button class="gbtn" id="lb-btn">排行榜</button>
        <button class="gbtn" id="logout-btn">退出登录</button>
      </div>
    </div>
  </div>

  <div class="user-bar">
    <div class="user-greeting">欢迎，<em id="g-username"></em></div>
    <div class="user-rank" id="g-rank"></div>
  </div>

  <div class="game-wrapper">
    <div class="board" id="board">
      <div class="cell"></div><div class="cell"></div><div class="cell"></div><div class="cell"></div>
      <div class="cell"></div><div class="cell"></div><div class="cell"></div><div class="cell"></div>
      <div class="cell"></div><div class="cell"></div><div class="cell"></div><div class="cell"></div>
      <div class="cell"></div><div class="cell"></div><div class="cell"></div><div class="cell"></div>
    </div>
    <div class="tiles-layer" id="tilesLayer"></div>
    <div class="overlay" id="ov-win">
      <div class="overlay-title">🎉 达成 2048！</div>
      <button class="gbtn" id="btn-continue">继续挑战</button>
      <button class="gbtn" id="btn-restart-win">重新开始</button>
    </div>
    <div class="overlay" id="ov-lose">
      <div class="overlay-title">游戏结束</div>
      <button class="gbtn" id="btn-restart-lose">再试一次</button>
    </div>
  </div>
  <div class="g-hint">方向键 / WASD 移动 &nbsp;·&nbsp; 支持触屏滑动</div>
</div>

<!-- ========== LEADERBOARD ========== -->
<div id="page-leaderboard" class="page hidden">
  <div class="lb-header">
    <div class="lb-title">排行榜</div>
    <button class="gbtn" id="lb-back">← 返回游戏</button>
  </div>
  <div class="lb-stats" id="lb-stats"></div>
  <div class="lb-list" id="lb-list"></div>
</div>

<script>
/* ===================================================
   STORAGE
=================================================== */
const DB = {
  users()        { return JSON.parse(localStorage.getItem('_2048_u') || '[]'); },
  saveUsers(arr) { localStorage.setItem('_2048_u', JSON.stringify(arr)); },
  session()      { return localStorage.getItem('_2048_s') || ''; },
  setSession(u)  { localStorage.setItem('_2048_s', u); },
  endSession()   { localStorage.removeItem('_2048_s'); },
  find(name)     { return DB.users().find(u => u.name === name) || null; },
  updateBest(name, s) {
    const arr = DB.users();
    const u = arr.find(u => u.name === name);
    if (u && s > u.best) { u.best = s; DB.saveUsers(arr); return true; }
    return false;
  }
};

/* ===================================================
   PAGE NAV
=================================================== */
const PAGES = ['login','register','game','leaderboard'];
function show(id) {
  PAGES.forEach(p => document.getElementById('page-'+p).classList.toggle('hidden', p !== id));
}

/* ===================================================
   AUTH
=================================================== */
function setErr(id, msg) {
  const el = document.getElementById(id);
  el.textContent = msg; el.classList.add('show');
}
function clrErr(id) { document.getElementById(id).classList.remove('show'); }

document.getElementById('to-reg').addEventListener('click',   () => { clrErr('login-err'); show('register'); });
document.getElementById('to-login').addEventListener('click',  () => { clrErr('reg-err');   show('login');    });

document.getElementById('login-btn').addEventListener('click', doLogin);
document.getElementById('l-pass').addEventListener('keydown', e => e.key==='Enter' && doLogin());

function doLogin() {
  clrErr('login-err');
  const name = document.getElementById('l-user').value.trim();
  const pass = document.getElementById('l-pass').value;
  if (!name || !pass) { setErr('login-err','请填写用户名和密码'); return; }
  const u = DB.find(name);
  if (!u || u.pass !== pass) { setErr('login-err','用户名或密码错误'); return; }
  DB.setSession(name);
  enterGame(name);
}

document.getElementById('reg-btn').addEventListener('click', doRegister);
document.getElementById('r-conf').addEventListener('keydown', e => e.key==='Enter' && doRegister());

function doRegister() {
  clrErr('reg-err');
  const name = document.getElementById('r-user').value.trim();
  const pass = document.getElementById('r-pass').value;
  const conf = document.getElementById('r-conf').value;
  if (!name || !pass) { setErr('reg-err','请填写所有字段'); return; }
  if (!/^[\w\u4e00-\u9fa5]{2,12}$/.test(name)) { setErr('reg-err','用户名需 2-12 位（字母、数字或中文）'); return; }
  if (pass.length < 6) { setErr('reg-err','密码至少 6 位'); return; }
  if (pass !== conf)   { setErr('reg-err','两次密码不一致'); return; }
  if (DB.find(name))   { setErr('reg-err','该用户名已被注册'); return; }
  const arr = DB.users();
  arr.push({ name, pass, best: 0 });
  DB.saveUsers(arr);
  DB.setSession(name);
  enterGame(name);
}

document.getElementById('logout-btn').addEventListener('click', () => {
  DB.endSession();
  document.getElementById('l-user').value = '';
  document.getElementById('l-pass').value = '';
  show('login');
});

/* ===================================================
   GAME
=================================================== */
const G = 4;
let grid, score, won, continueMode, over, me;

function enterGame(name) {
  me = name;
  const u = DB.find(name);
  document.getElementById('g-username').textContent = name;
  document.getElementById('best').textContent = u.best;
  updateRankDisplay();
  show('game');
  initGame();
}

function initGame() {
  grid = Array.from({length:G}, () => Array(G).fill(0));
  score = 0; won = false; continueMode = false; over = false;
  document.getElementById('score').textContent = 0;
  spawnTile(); spawnTile();
  render();
  hideOv();
}

function addScore(n) {
  score += n;
  document.getElementById('score').textContent = score;
  if (DB.updateBest(me, score)) {
    document.getElementById('best').textContent = score;
    updateRankDisplay();
  }
}

function updateRankDisplay() {
  const users = DB.users().sort((a,b)=>b.best-a.best);
  const idx = users.findIndex(u=>u.name===me);
  const el = document.getElementById('g-rank');
  if (idx >= 0) {
    const r = idx+1;
    el.textContent = r===1 ? '🥇 排名第一' : r===2 ? '🥈 排名第二' : r===3 ? '🥉 排名第三' : `排名第 ${r}`;
  } else { el.textContent = ''; }
}

function spawnTile() {
  const empty = [];
  for (let r=0;r<G;r++) for (let c=0;c<G;c++) if (!grid[r][c]) empty.push([r,c]);
  if (!empty.length) return null;
  const [r,c] = empty[Math.floor(Math.random()*empty.length)];
  grid[r][c] = Math.random()<0.9 ? 2 : 4;
  return [r,c];
}

function slideRow(row) {
  const nums = row.filter(v=>v);
  const out=[], mat=[];
  let i=0;
  while(i<nums.length) {
    if (i+1<nums.length && nums[i]===nums[i+1]) {
      const v = nums[i]*2; out.push(v); mat.push(out.length-1);
      addScore(v);
      if (v===2048 && !won) won=true;
      i+=2;
    } else { out.push(nums[i]); i++; }
  }
  while(out.length<G) out.push(0);
  return {row:out, mat};
}

function move(dir) {
  if (over) return;
  let moved=false;
  const merges=[];

  if (dir==='left'||dir==='right') {
    for(let r=0;r<G;r++) {
      const rev=dir==='right';
      const src = rev?[...grid[r]].reverse():[...grid[r]];
      const {row:nr,mat} = slideRow(src);
      const fin = rev?[...nr].reverse():nr;
      if(fin.some((v,i)=>v!==grid[r][i])) moved=true;
      grid[r]=fin;
      (rev?mat.map(i=>G-1-i):mat).forEach(c=>merges.push([r,c]));
    }
  } else {
    for(let c=0;c<G;c++) {
      const col=grid.map(r=>r[c]);
      const rev=dir==='down';
      const src=rev?[...col].reverse():[...col];
      const {row:nr,mat}=slideRow(src);
      const fin=rev?[...nr].reverse():nr;
      for(let r=0;r<G;r++){if(fin[r]!==grid[r][c]) moved=true; grid[r][c]=fin[r];}
      (rev?mat.map(i=>G-1-i):mat).forEach(r=>merges.push([r,c]));
    }
  }

  if(!moved) return;
  const sp=spawnTile();
  render(merges,sp);
  if(won && !continueMode){ showOv('win'); return; }
  if(isOver()){ over=true; showOv('lose'); }
}

function isOver() {
  for(let r=0;r<G;r++) for(let c=0;c<G;c++){
    if(!grid[r][c]) return false;
    if(c+1<G && grid[r][c]===grid[r][c+1]) return false;
    if(r+1<G && grid[r][c]===grid[r+1][c]) return false;
  }
  return true;
}

function render(merges=[],sp=null) {
  const layer=document.getElementById('tilesLayer');
  const cells=document.getElementById('board').querySelectorAll('.cell');
  const r0=cells[0].getBoundingClientRect(), r1=cells[1].getBoundingClientRect();
  if(!r0.width){ requestAnimationFrame(()=>render(merges,sp)); return; }
  const cs=r0.width, gap=r1.left-r0.right;
  layer.innerHTML='';
  for(let r=0;r<G;r++) for(let c=0;c<G;c++){
    const v=grid[r][c]; if(!v) continue;
    const el=document.createElement('div');
    el.className='tile '+tCls(v);
    el.style.cssText=`width:${cs}px;height:${cs}px;left:${c*(cs+gap)}px;top:${r*(cs+gap)}px;font-size:${fSize(v,cs)}`;
    el.textContent=v;
    if(merges.some(([mr,mc])=>mr===r&&mc===c)) el.classList.add('merge');
    else if(sp&&sp[0]===r&&sp[1]===c) el.classList.add('new');
    layer.appendChild(el);
  }
}
function tCls(v){ return v<=2048?'t'+v:'tsuper'; }
function fSize(v,cs){
  const l=String(v).length, b=cs*.38;
  return (l<=2?b:l===3?b*.75:l===4?b*.6:b*.48)+'px';
}
function showOv(t){ document.getElementById(t==='win'?'ov-win':'ov-lose').classList.add('show'); }
function hideOv(){ document.getElementById('ov-win').classList.remove('show'); document.getElementById('ov-lose').classList.remove('show'); }

// game buttons
document.getElementById('new-btn').addEventListener('click', initGame);
document.getElementById('btn-continue').addEventListener('click',()=>{ continueMode=true; hideOv(); });
document.getElementById('btn-restart-win').addEventListener('click', initGame);
document.getElementById('btn-restart-lose').addEventListener('click', initGame);

// keyboard
document.addEventListener('keydown', e=>{
  if(document.getElementById('page-game').classList.contains('hidden')) return;
  const m={ArrowLeft:'left',ArrowRight:'right',ArrowUp:'up',ArrowDown:'down',
           a:'left',d:'right',w:'up',s:'down',A:'left',D:'right',W:'up',S:'down'};
  const dir=m[e.key]; if(dir){ e.preventDefault(); move(dir); }
});

// touch
let tx,ty;
document.getElementById('board').addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY;},{passive:true});
document.getElementById('board').addEventListener('touchend',e=>{
  if(over) return;
  const dx=e.changedTouches[0].clientX-tx, dy=e.changedTouches[0].clientY-ty;
  if(Math.abs(dx)<20&&Math.abs(dy)<20) return;
  move(Math.abs(dx)>Math.abs(dy)?(dx>0?'right':'left'):(dy>0?'down':'up'));
},{passive:true});

window.addEventListener('resize',()=>{ if(!document.getElementById('page-game').classList.contains('hidden')) render(); });

/* ===================================================
   LEADERBOARD
=================================================== */
const COLORS=['#f67c5f','#f2b179','#edcf72','#5ba4cf','#9b59b6','#2ecc71','#e74c3c','#3498db','#1abc9c','#e67e22'];
function avatarColor(name){
  let h=0; for(let i=0;i<name.length;i++) h=(h*31+name.charCodeAt(i))%COLORS.length;
  return COLORS[h];
}
function esc(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function renderLB() {
  const users=DB.users().sort((a,b)=>b.best-a.best);
  const total=users.length;
  const maxBest=users.length?users[0].best:0;
  const myRank=(users.findIndex(u=>u.name===me)+1)||'-';

  // stats bar
  document.getElementById('lb-stats').innerHTML=`
    <div class="lb-stat-box"><div class="lb-stat-num">${total}</div><div class="lb-stat-lbl">总玩家</div></div>
    <div class="lb-stat-box"><div class="lb-stat-num">${maxBest.toLocaleString()}</div><div class="lb-stat-lbl">历史最高</div></div>
    <div class="lb-stat-box"><div class="lb-stat-num">${myRank}</div><div class="lb-stat-lbl">我的排名</div></div>
  `;

  const list=document.getElementById('lb-list');
  if(!users.length){ list.innerHTML='<div class="lb-empty">暂无记录</div>'; return; }

  list.innerHTML=users.map((u,i)=>{
    const rank=i+1;
    const isMe=u.name===me;
    const rankHtml=rank===1?`<div class="lb-rank rank-1">🥇</div>`
                  :rank===2?`<div class="lb-rank rank-2">🥈</div>`
                  :rank===3?`<div class="lb-rank rank-3">🥉</div>`
                  :`<div class="lb-rank rank-n">${rank}</div>`;
    return `
      <div class="lb-item${isMe?' me':''}">
        ${rankHtml}
        <div class="lb-avatar" style="background:${avatarColor(u.name)}">${esc(u.name.charAt(0).toUpperCase())}</div>
        <div class="lb-info">
          <div class="lb-name">
            ${esc(u.name)}
            ${isMe?'<span class="lb-badge">◀ 我</span>':''}
          </div>
          <div class="lb-slabel">最高分</div>
          <div class="lb-score">${u.best.toLocaleString()}</div>
        </div>
      </div>`;
  }).join('');
}

document.getElementById('lb-btn').addEventListener('click', ()=>{ renderLB(); show('leaderboard'); });
document.getElementById('lb-back').addEventListener('click', ()=>show('game'));

/* ===================================================
   BOOT
=================================================== */
(function boot(){
  const s=DB.session();
  if(s && DB.find(s)) enterGame(s);
  else show('login');
})();
</script>
